# Application
APP_NAME="Stake Bet Lookup"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database — matches docker-compose mysql service
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=stake_app
DB_USERNAME=stake
DB_PASSWORD=secret

# Mail — points to Mailpit SMTP inside Docker
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@stake-lookup.local"
MAIL_FROM_NAME="${APP_NAME}"

# Cache / Session
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Stake API
STAKE_API_URL=https://stake.games/_api/graphql
STAKE_ACCESS_TOKEN=

# Admin — store the SHA-256 hash of your token, not the raw token
# Generate: TOKEN=$(openssl rand -hex 32) && echo "Token: $TOKEN" && echo -n $TOKEN | sha256sum | cut -d' ' -f1
STAKE_ADMIN_TOKEN=

# Alerts — Mailpit catches all email locally (http://localhost:8025)
STAKE_CLEARANCE_ALERT_EMAIL=admin@example.com

# Optional
STAKE_CLEARANCE_ALERT_SLACK_WEBHOOK=
STAKE_CLEARANCE_WARNING_THRESHOLD=3600
BET_LOOKUP_RATE_LIMIT=60
BET_LOOKUP_TIMEOUT=10
