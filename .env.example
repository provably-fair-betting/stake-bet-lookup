# ── Required secrets (never commit the filled-in .env.example) ─────────────

# Laravel application key — generated automatically by make setup, or manually:
#   docker run --rm --entrypoint php verifierform-stake-bet-lookup:local artisan key:generate --show
APP_KEY=

# SHA-256 hash of the raw admin bearer token — generate a pair with:
#   RAW=$(openssl rand -hex 32)
#   echo "Raw token : $RAW"
#   echo "Hash (STAKE_ADMIN_TOKEN): $(echo -n $RAW | sha256sum | awk '{print $1}')"
# Store the raw token somewhere safe — you need it for make capture / sync-config.json.
STAKE_ADMIN_TOKEN=

# ── Stake API ──────────────────────────────────────────────────────────────────
STAKE_API_URL=https://stake.games/_api/graphql
# STAKE_ACCESS_TOKEN=   # only needed if stake.games requires an access token

# ── Optional tuning ───────────────────────────────────────────────────────────
# BET_LOOKUP_RATE_LIMIT=60
# BET_LOOKUP_CACHE_TTL=300
# BET_LOOKUP_TIMEOUT=10

# ── Port ──────────────────────────────────────────────────────────────────────
PORT=8080
